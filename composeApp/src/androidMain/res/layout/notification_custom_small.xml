<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent"
    android:orientation="horizontal"
    android:padding="4dp">

    <ImageView
        android:id="@+id/notification_avatar"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_gravity="center_vertical"
        android:scaleType="centerCrop"
        android:background="@drawable/circle_background"
        android:contentDescription="@string/partner_avatar"
        android:src="@drawable/avatar1" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/notification_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Partner Name"
            android:textColor="@color/partner_name"
            android:textSize="14sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/notification_battery_icon"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:contentDescription="@string/battery_status"
                android:src="@drawable/ic_battery_status" />

            <TextView
                android:id="@+id/notification_battery"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="85%"
                android:textColor="@color/status_text"
                android:textSize="11sp" />

            <ImageView
                android:id="@+id/notification_signal_icon"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_marginStart="8dp"
                android:contentDescription="@string/signal_status"
                android:src="@drawable/ic_signal_status" />

            <TextView
                android:id="@+id/notification_network"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="LTE"
                android:textColor="@color/status_text"
                android:textSize="11sp" />

            <ImageView
                android:id="@+id/notification_speed_icon"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_marginStart="8dp"
                android:contentDescription="@string/speed_status"
                android:src="@drawable/ic_speed"
                android:visibility="gone" />

            <TextView
                android:id="@+id/notification_speed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:textColor="@color/status_text"
                android:textSize="11sp"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>